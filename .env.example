# HelloBMG Backend — copy to .env and fill in your values

# MySQL (phpMyAdmin local setup)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hellobmg
DB_USER=root
DB_PASSWORD=

# Base URL used to build image URLs
BASE_URL=http://localhost:8010

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://localhost:3000,https://www.hellobmg.com
